# Copy to .env.supabase.local and fill with real values.
# This file is safe to commit. The .local file is git-ignored.

# Option A: provide both
SUPABASE_PROJECT_REF=
SUPABASE_DB_PASSWORD=

# Option B: provide full URL instead
# postgresql://postgres:<db_password>@db.<project_ref>.supabase.co:5432/postgres?sslmode=require
SUPABASE_DB_URL=
